#!/usr/bin/env sh
set -e

# Gather staged Lua files
staged_lua=$(git diff --cached --name-only --diff-filter=ACM | grep '\.lua$' || true)

if [ -z "$staged_lua" ]; then
  exit 0
fi

# Run all checks (lint, typecheck, selene)
# Each tool skips gracefully if not installed, warns about what's missing
make check
